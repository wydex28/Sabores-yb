# --------------------------------------------------------------------------
# CONFIGURACIÓN DE NÚCLEO (LARAVEL)
# --------------------------------------------------------------------------
APP_NAME="Sabores Y&B"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --------------------------------------------------------------------------
# BASE DE DATOS (SISTEMA USA SQLITE POR DEFECTO)
# --------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# --------------------------------------------------------------------------
# SESIONES, CACHÉ Y COLAS (ALMACENADOS EN DB)
# --------------------------------------------------------------------------
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# --------------------------------------------------------------------------
# SEGURIDAD Y ACCESO ADMINISTRATIVO
# --------------------------------------------------------------------------
# Contraseña para el panel de gestión diaria (/admin)
ADMIN_PASSWORD=admin123

# Contraseña maestra para el panel de infraestructura (/superadmin)
SUPER_ADMIN_PASSWORD=SABORES2026

# --------------------------------------------------------------------------
# SERVICIOS ADICIONALES
# --------------------------------------------------------------------------
# Correo electrónico (Configurado en modo Log para desarrollo)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hola@saboresyb.com"
MAIL_FROM_NAME="${APP_NAME}"

# Archivos
FILESYSTEM_DISK=public

# Vite (Frontend)
VITE_APP_NAME="${APP_NAME}"
